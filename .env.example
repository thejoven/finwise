# Copy to .env and fill in real values. .env is gitignored.

# --- Database ---
# Matches docker-compose.yml defaults.
DATABASE_URL=postgres://alphax:dev_password_change_me@localhost:5432/alphax?sslmode=disable

# --- iii orchestration engine ---
# iii engine 跑在 host 上 (systemd), Redis 跑在 docker-compose.
# III_HTTP_URL: Go outbox 推事件到 iii 的 HTTP worker. Compose 里走
# host.docker.internal; Mac 本地 dev 直接 localhost.
III_HTTP_URL=http://localhost:3111
# III_URL: Mastra SDK worker 通过 WS 连到 iii engine. 同上.
III_URL=ws://localhost:49134
# REDIS_URL: iii 自己用; 项目里其他地方暂不用 redis.
REDIS_URL=redis://localhost:6379

# --- HTTP server ---
PORT=8080

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info

# --- Dev bearer (backward-compat single-user token) ---
# Auth 现在支持两种 Bearer:
#   (a) DEV_BEARER_TOKEN — 单用户兼容路径. mastra/web-admin/curl 用这个,
#       请求落到 DEV_USER_ID. users 表会自动 seed 一行 placeholder.
#   (b) sessions 表里的 token — 通过 POST /v1/auth/register 或 /v1/auth/login 拿到.
#       客户端 (mobile) 走这个路径, 支持多用户.
# Generate user_id once: uuidgen
DEV_USER_ID=
DEV_BEARER_TOKEN=dev-token-change-me

# --- Internal worker auth ---
# Mastra worker (Node) sends this in X-Internal-Token to /v1/internal/*.
# Pick something hard to guess; not a security boundary in Phase 1 but a wrong-call guard.
INTERNAL_TOKEN=internal-secret-change-me

# If true, /v1/internal/* will refuse non-loopback callers. Set false when
# Mastra runs in a separate container that hits the api via the host network.
INTERNAL_LOOPBACK=true

# --- Outbox publisher tuning ---
# 不设走默认值. 生产想加吞吐量调 BATCH, 想降延迟调 POLL_MS, 想容忍更多失败调 MAX_ATTEMPTS.
# OUTBOX_POLL_MS=500
# OUTBOX_BATCH=10
# OUTBOX_MAX_ATTEMPTS=5

# --- Mastra HTTP (M6 G2 / M9 Editor / M11 Diagnostician) ---
# 不设 (留空) → Go 走启发式 stub, 主流程不阻塞. 设了 → 同步调 Mastra.
# Mastra 在哪跑: cd mastra && npm run dev → 默认 listen 127.0.0.1:9090
# MASTRA_HTTP_URL=http://localhost:9090

# --- 语音转写 ASR (signal 模块, /v1/signals/transcribe 代理) ---
# 自托管 GLM-ASR 服务地址 (alphax-asr.service, 仅 loopback). 留空用下面默认值.
# 部署见 asr/README.md.
# ASR_SERVICE_URL=http://127.0.0.1:18900

# --- 推文订阅 (subscription 模块) ---
# twtapi.com 的 X-API-Key, 采集订阅账号的推文用. 在 twtapi.com 后台获取.
# 留空 → 采集 poller 不启动, 订阅 REST 仍可读历史 (优雅降级).
# TWTAPI_API_KEY=
# SUBSCRIPTION_POLL_ENABLED=true   # 显式关采集 worker (调试/省配额) 时设 false

# --- Mastra (Node) — used by mastra/ project ---
#
# LLM provider 走 OpenAI-compatible 接口. 默认接 DeepSeek; 切其他 provider
# 改这两个 var 就够 (代码不动).
#
# DeepSeek 控制台拿 key: https://platform.deepseek.com/api_keys
# LLM_API_KEY=sk-... 必填 (provider-neutral 命名)
# LLM_BASE_URL=https://api.deepseek.com    默认 (可省)
# ANALYST_MODEL=deepseek-chat              默认 deepseek-chat;
#                                           想用 deepseek-reasoner / 其他, 改这里
#
# 旧 ANTHROPIC_API_KEY 仍兼容 (在没有 LLM_API_KEY / DEEPSEEK_API_KEY 时 fallback).
#
# ALPHAX_API_URL=http://localhost:8080
# INTERNAL_TOKEN=... (与 server .env 的 INTERNAL_TOKEN 同值)
