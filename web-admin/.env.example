# Web admin env. Copy to .env.local to override.
#
# VITE_API_BASE_URL — runtime API base prefix.
#   Leave empty (default) so the admin uses relative paths.
#   `npm run dev` then proxies /v1, /healthz, /metrics via vite.config.ts.
#   In production nginx is the proxy.
# VITE_API_BASE_URL=
#
# VITE_DEV_API_TARGET — only used by the vite dev/preview proxy.
# Default: http://192.168.1.205:8080
# VITE_DEV_API_TARGET=http://192.168.1.205:8080
