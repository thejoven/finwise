# Public vars must use EXPO_PUBLIC_ prefix to reach the JS bundle.

# Where the Go API lives.
# Default points at the dev intranet server (192.168.1.205).
# - iOS Simulator: http://192.168.1.205:8080 (same LAN as your Mac)
# - Real iPhone: same URL works as long as the phone is on the same LAN
# - Going back to localhost: only if you ever run the Go server on your Mac
EXPO_PUBLIC_API_URL=http://192.168.1.205:8080

# Dev auto-login (默认关闭). 设为 1 时, 没登录会直接用下面的 dev bearer 进
# inbox 并给所有请求签名 — 单用户调试用. 默认/未设 → 正常跳 /login.
EXPO_PUBLIC_DEV_AUTOLOGIN=0

# 仅在 EXPO_PUBLIC_DEV_AUTOLOGIN=1 时生效.
# Must match the server's /opt/alphax/.env DEV_BEARER_TOKEN.
# Current value on 192.168.1.205 (auto-generated 2026-05-25):
#   uaR0GcVn_aEX0E4DzIz0mQXuUlDnzRW9
# If you rotate it on the server, mirror it here.
EXPO_PUBLIC_DEV_BEARER_TOKEN=uaR0GcVn_aEX0E4DzIz0mQXuUlDnzRW9
