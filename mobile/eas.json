{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.205:8080"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.205:8080"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.alphax.example.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ALPHAX_APPLE_ID",
        "ascAppId": "ALPHAX_ASC_APP_ID",
        "appleTeamId": "ALPHAX_APPLE_TEAM_ID"
      }
    }
  }
}
