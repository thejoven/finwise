{
  "name": "flashfi-mastra",
  "version": "0.1.0",
  "private": true,
  "description": "LLM orchestration for Flashfi Engine — Analyst Agent + NATS consumer.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "eval": "tsx tests/manual-eval/run.ts",
    "eval:consensus": "tsx tests/eval/consensus/run.ts",
    "eval:editor": "tsx tests/eval/editor/run.ts",
    "eval:diagnostician": "tsx tests/eval/diagnostician/run.ts",
    "eval:all": "npm run eval && npm run eval:consensus && npm run eval:editor && npm run eval:diagnostician",
    "lint": "prettier --check src tests"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "@mastra/core": "^0.10.0",
    "@mastra/memory": "^0.10.4",
    "@mastra/pg": "^0.10.3",
    "ai": "^4.0.0",
    "nats": "^2.28.0",
    "undici": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
