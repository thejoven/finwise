# Copy to mastra/.env

# ───── LLM provider (OpenAI-compatible) ─────
#
# 默认 DeepSeek. 切 OpenAI / Anthropic-via-proxy / Ollama 改这两个 var 就够,
# 代码不动.
#
# DeepSeek key 控制台: https://platform.deepseek.com/api_keys
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com

# 模型名. DeepSeek 公开模型:
#   - deepseek-chat       (V3 系列, 默认)
#   - deepseek-reasoner   (R1, 慢但推理强, 适合 Diagnostician/Narrator)
# 想用别的模型 (e.g. deepseek-v4-pro 如果你的账号有) 改这里.
ANALYST_MODEL=deepseek-chat
ANALYST_MAX_TOKENS=1500
ANALYST_TEMPERATURE=0.3

# 旧 ANTHROPIC_API_KEY 还兼容 (在 LLM_API_KEY 缺失时 fallback). 想回 Claude:
#   1. LLM_BASE_URL 留空 (或删) — 但目前 code 强制走 OpenAI-compat 路径, 实际
#      要回 Claude 需要恢复 @ai-sdk/anthropic, 见 git log.
# ANTHROPIC_API_KEY=

# ───── iii engine (orchestration) — replaces NATS ─────
# WebSocket endpoint for the SDK worker; iii engine runs as systemd on the host.
III_URL=ws://192.168.1.205:49134

# ───── Go API (internal endpoint for writing inference back) ─────
FLASHFI_API_URL=http://192.168.1.205:8080

# Must match /opt/flashfi/.env INTERNAL_TOKEN on the server.
INTERNAL_TOKEN=

# ───── Mastra HTTP server (Go 同步调用 ConsensusCheck/Editor/Diagnostician) ─────
# 默认 loopback. 跑在 Mac 让远程 Go server 调用时, bind 改 0.0.0.0 + 设防火墙.
MASTRA_HTTP_BIND=127.0.0.1
MASTRA_HTTP_PORT=9090

# ───── Exa.ai Web Search (Analyst + Socratic 实时检索) ─────
#
# Dashboard: https://dashboard.exa.ai  · Docs: https://exa.ai/docs
# 没填 key 时整条搜索路径静默 no-op (Analyst 仍能跑, 只是少了 grounding).
EXA_API_KEY=
EXA_SEARCH_URL=https://api.exa.ai/search
EXA_SEARCH_TIMEOUT_MS=8000

# ───── Logging ─────
LOG_LEVEL=info
