# Docker 部署专用 env. 拷成 .env (单文件复用) 或 .env.docker, 再 docker compose 引用.
# 本地开发 (docker compose 不带 --profile prod) 用根目录的 .env.example 拷出来的 .env.

# --- Postgres ---
# 注意: 改了之后, migrator + api 都会用这套. 老库要先 dump.
POSTGRES_DB=alphax
POSTGRES_USER=alphax
POSTGRES_PASSWORD=change_me_now

# --- 宿主端口绑定 ---
# 如果想只暴露在 127.0.0.1, 把这些改成 "127.0.0.1:8080" 之类.
# 默认监听 0.0.0.0, 局域网可访问.
API_HOST_PORT=8080
ADMIN_HOST_PORT=8082
POSTGRES_HOST_PORT=5432
# 205 上 mm-redis 占了 6379, 这里默认绕到 6380. 没冲突的环境改回 6379 也行.
REDIS_HOST_PORT=6380
# iii engine 跑在 host 的 systemd, 不在 compose. 默认端口 3111 (HTTP) / 49134 (WS).

# --- Server (Go API) ---
# uuidgen 生成一次, 长期固定. 不要用 placeholder.
DEV_USER_ID=
# 客户端 / web-admin / curl 兜底 token. mobile 走 sessions 表多用户路径时与之并存.
DEV_BEARER_TOKEN=change_me_now
# api ↔ mastra 之间的内部 token.
INTERNAL_TOKEN=change_me_now
# 注意: docker 网络里容器之间不算 loopback, 这里必须 false.
INTERNAL_LOOPBACK=false
LOG_LEVEL=info

# Outbox publisher tuning (留空走默认值).
# OUTBOX_POLL_MS=500
# OUTBOX_BATCH=10
# OUTBOX_MAX_ATTEMPTS=5

# --- Mastra (LLM) ---
# OpenAI-compatible. 默认接 DeepSeek; 想换 provider 改 LLM_BASE_URL + ANALYST_MODEL.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
ANALYST_MODEL=deepseek-chat

# Optional. 没填会静默 no-op (Analyst 仍跑, 没有 web grounding).
EXA_API_KEY=

# Optional. Embeddings: pgvector store / thicknessJudge.
# 没填 → 那条路径 fallback. 默认走 dashscope text-embedding-v3.
DASHSCOPE_API_KEY=

# --- 构建镜像源 (在墙内构建时可切到 mirror) ---
# GOPROXY=https://goproxy.cn,direct
# NPM_REGISTRY=https://registry.npmmirror.com/
